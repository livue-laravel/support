{
    "name": "primix/support",
    "description": "Core support utilities for Primix admin panel framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Support\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Support\\PrimixSupportServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
